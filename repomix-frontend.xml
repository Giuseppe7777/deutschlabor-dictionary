          {{ 'pages.register.form.submit' | translate }}
        }
      </button>
    </fieldset>

      @if (isRegistered()) {
        <p class="form-success">
          {{ 'pages.register.form.messages.registered' | translate }}
        </p>
      }

      @if (submitError(); as errorKey) {
        <p class="form-error form-submit-error">
          {{ errorKey | translate }}
        </p>
      }

