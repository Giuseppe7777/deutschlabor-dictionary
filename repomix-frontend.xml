          @for (word of words(); track word.id) {
            <li>
              <strong>{{ word.word }}</strong>
              @if (word.translation) {
                <span>{{ word.translation }}</span>
              }
            </li>
          }
        </ul>
      } @else {
        <p>{{ 'pages.training.status.empty' | translate }}</p>
      }
    } @else if (status() === 'anonymous') {
      <div class="state-card">
        <h2>{{ 'pages.training.status.anonymous.title' | translate }}</h2>
        <p>{{ 'pages.training.status.anonymous.message' | translate }}</p>

        <div class="action-row">
          <a class="action-link" [routerLink]="loginPath()">
            {{ 'auth.login' | translate }}
          </a>
          <a class="action-link action-link-secondary" [routerLink]="registerPath()">
            {{ 'auth.register' | translate }}
          </a>
        </div>
      </div>
    } @else if (status() === 'email_verification_required') {
      <div class="state-card">
        <h2>{{ 'pages.training.status.emailVerificationRequired.title' | translate }}</h2>
        <p>{{ 'pages.training.status.emailVerificationRequired.message' | translate }}</p>
      </div>
    } @else if (status() === 'rate_limited') {
      <div class="state-card">
        <h2>{{ 'pages.training.status.rateLimited.title' | translate }}</h2>
        <p>{{ 'pages.training.status.rateLimited.message' | translate }}</p>

        @if (retryAfterSeconds() !== null) {
