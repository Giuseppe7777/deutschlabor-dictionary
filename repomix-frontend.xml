          </button>

          <button
            class="passkey-modal-primary"
            type="button"
            [disabled]="isSubmitting()"
            (click)="continueRegistrationWithPasskey()"
          >
            @if (isSubmitting()) {
              {{ 'pages.register.form.submitting' | translate }}
            } @else {
              {{ 'pages.register.passkeyModal.createPasskey' | translate }}
            }
          </button>
        </div>
      </section>
    </div>
  }
</section>
