  align-items: center;
  justify-content: center;
  min-width: 1.25rem;
  height: 1.25rem;
  border-radius: 999px;
  background: #f59e0b;
  color: #111827;
  font-size: 0.75rem;
  font-weight: var(--app-font-weight-bold);
}

.header-actions {
  display: flex;
  justify-self: end;
  align-items: center;
  gap: 1rem;
}

.auth-links {
  display: flex;
  align-items: center;
  gap: 0.35rem;
}

.auth-links:not(:has(a.auth-active)) .auth-primary,
.auth-links a.auth-active {
  border-color: #111827;
  background: #111827;
  color: #ffffff;
}

.auth-links:not(:has(a.auth-active)) .auth-primary:hover,
.auth-links a.auth-active:hover {
  background: #1f2937;
  color: #ffffff;
}

.user-area {
  display: grid;
  justify-items: end;
  gap: 0.35rem;
}

.user-session {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.user-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.55rem;
  max-width: 18rem;
  border: 1px solid #b6cefa;
  border-radius: 999px;
  padding: 0.35rem 0.75rem 0.35rem 0.35rem;
  color: #111827;
  text-decoration: none;
  font-size: var(--app-font-size-ui);
  font-weight: var(--app-font-weight-medium);
}

.user-chip:hover {
  border-color: #dbe7fe;
  background: #dbe7fe;
}

.user-avatar {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  border-radius: 999px;
  background: #111827;
  color: #ffffff;
  font-size: 0.85rem;
  font-weight: var(--app-font-weight-bold);
}

.user-email {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.logout-button {
  border: 1px solid #fecaca;
  border-radius: 999px;
  padding: 0.55rem 0.85rem;
  background: #ffffff;
  color: #991b1b;
  cursor: pointer;
  font: inherit;
  font-size: var(--app-font-size-small);
  font-weight: var(--app-font-weight-bold);
}

.logout-button:hover:not(:disabled) {
  border-color: #991b1b;
  background: #fee2e2;
}

.logout-button:disabled {
  cursor: wait;
  opacity: 0.65;
}

.logout-error {
  margin: 0;
  color: #991b1b;
  font-size: var(--app-font-size-small);
  font-weight: var(--app-font-weight-medium);
}

@media (max-width: 900px) {
  .app-header {
    display: flex;
    align-items: flex-start;
    flex-direction: column;
  }

  .brand {
    width: min(18rem, 100%);
  }

  .main-nav,
  .header-actions {
    width: 100%;
    flex-wrap: wrap;
  }

  .main-nav,
  .header-actions {
    justify-self: auto;
  }

  .user-area {
    justify-items: start;
  }

  .user-session {
    flex-wrap: wrap;
  }
}

@media (max-width: 700px) {
  .brand {
    max-width: 100%;
  }

  .brand-logo {
    width: 13.5rem;
  }

  .brand-slogan {
    padding-left: 0;
    font-size: 0.62rem;
    line-height: 1.15;
    white-space: normal;
  }

  .main-nav a,
  .auth-links a,
  .user-chip,
  .logout-button {
    min-width: auto;
  }
}
</file>

<file path="src/app/layout/header/header.html">
<div class="app-header" [class.is-language-change-pending]="isLanguageChangePending()">
  <a class="brand" [routerLink]="localizedPath('')" aria-label="DeutschLabor">
    <img
      class="brand-logo"
      src="/brand/dl-logo.png"
      alt="DeutschLabor"
      width="2172"
      height="724"
    >

    <span class="brand-slogan">
      {{ 'header.slogan' | translate }}
    </span>
  </a>

  <nav class="main-nav" [attr.aria-label]="'header.mainNavigation' | translate">
    <a
      [routerLink]="localizedPath('')"
      routerLinkActive="is-active"
      [routerLinkActiveOptions]="{ exact: true }"
    >
      {{ 'nav.search' | translate }}
    </a>

    <a [routerLink]="localizedPath('training')" routerLinkActive="is-active">
      {{ 'nav.training' | translate }}
      <span class="nav-badge">0</span>
    </a>

    <a [routerLink]="localizedPath('account')" routerLinkActive="is-active">
      {{ 'nav.account' | translate }}
    </a>
  </nav>

  <div class="header-actions">
    <app-language-switcher
      (languageChangePendingChange)="setLanguageChangePending($event)"
    />

    @if (isAuthenticated()) {
      <div class="user-area">
        <div class="user-session">
          <a class="user-chip" [routerLink]="localizedPath('account')">
            <span class="user-avatar" aria-hidden="true">
              {{ userInitial() }}
            </span>

            <span class="user-email">
              {{ userEmail() }}
            </span>
          </a>

          <button
            type="button"
            class="logout-button"
            [disabled]="isLogoutPending()"
            [attr.aria-busy]="isLogoutPending() ? 'true' : null"
            (click)="logout()"
          >
            @if (isLogoutPending()) {
              {{ 'auth.logoutPending' | translate }}
            } @else {
              {{ 'auth.logout' | translate }}
            }
          </button>
        </div>

        @if (logoutErrorKey(); as errorKey) {
          <p class="logout-error" role="alert">
            {{ errorKey | translate }}
          </p>
        }
      </div>
    } @else if (isAnonymous()) {
      <div class="auth-links">
        <a
          [routerLink]="localizedPath('login')"
          routerLinkActive="auth-active"
          [routerLinkActiveOptions]="{ exact: true }"
        >
          {{ 'auth.login' | translate }}
        </a>

        <a
          class="auth-primary"
          [routerLink]="localizedPath('register')"
          routerLinkActive="auth-active"
          [routerLinkActiveOptions]="{ exact: true }"
        >
          {{ 'auth.register' | translate }}
        </a>
      </div>
    }
  </div>
</div>
</file>

<file path="src/app/layout/header/header.ts">
import { Component, computed, inject, signal } from '@angular/core';
import { Router, RouterLink, RouterLinkActive } from '@angular/router';
import { TranslatePipe } from '@ngx-translate/core';
import { finalize } from 'rxjs';

import { InterfaceLanguageService } from '../../core/i18n/interface-language.service';
import { AuthStateService } from '../../features/auth/services/auth-state.service';
import { LanguageSwitcher } from './language-switcher/language-switcher';

@Component({
  selector: 'app-header',
  imports: [RouterLink, RouterLinkActive, TranslatePipe, LanguageSwitcher],
  templateUrl: './header.html',
  styleUrl: './header.css',
})
export class Header {
  private readonly router = inject(Router);
  private readonly interfaceLanguageService = inject(InterfaceLanguageService);
  private readonly authState = inject(AuthStateService);

  readonly currentLanguage = this.interfaceLanguageService.currentLanguage;
  readonly isLanguageChangePending = signal(false);

  readonly isAnonymous = this.authState.isAnonymous;
  readonly isAuthenticated = this.authState.isAuthenticated;
  readonly currentUser = this.authState.user;

  readonly isLogoutPending = signal(false);
  readonly logoutErrorKey = signal<string | null>(null);

  readonly userEmail = computed(() => this.currentUser()?.email ?? '');

  readonly userInitial = computed(() => {
    const email = this.userEmail();

    return email.length > 0 ? email.charAt(0).toUpperCase() : '?';
  });

  localizedPath(path: string): string[] {
    const segments = path.split('/').filter(Boolean);

    return ['/', this.currentLanguage(), ...segments];
  }

  setLanguageChangePending(isPending: boolean): void {
    this.isLanguageChangePending.set(isPending);
  }

  logout(): void {
    if (this.isLogoutPending()) {
      return;
    }

    this.logoutErrorKey.set(null);
    this.isLogoutPending.set(true);

    this.authState
      .logout()
      .pipe(
        finalize(() => {
          this.isLogoutPending.set(false);
        }),
      )
      .subscribe({
        next: () => {
          void this.router.navigate(this.localizedPath(''));
        },
        error: (error) => {
          if (error?.status === 401) {
            this.authState.clearAuthenticatedUser();
            void this.router.navigate(this.localizedPath(''));
            return;
          }

          this.logoutErrorKey.set('auth.logoutError');
        },
      });
  }
}
</file>

