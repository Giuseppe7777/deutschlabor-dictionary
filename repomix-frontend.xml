        />

        @if (isInvalid('firstName')) {
          <p class="form-error">
            {{ 'pages.register.form.firstName.error' | translate }}
          </p>
        }
      </div>

      <div class="form-field">
        <label for="lastName">
          {{ 'pages.register.form.lastName.label' | translate }}
        </label>

        <input
          id="lastName"
          type="text"
          formControlName="lastName"
          autocomplete="family-name"
          [placeholder]="
            'pages.register.form.lastName.placeholder' | translate
          "
          [class.is-invalid]="isInvalid('lastName')"
        />

        @if (isInvalid('lastName')) {
          <p class="form-error">
            {{ 'pages.register.form.lastName.error' | translate }}
          </p>
        }
      </div>

      <div class="form-field">
        <label for="email">
          {{ 'pages.register.form.email.label' | translate }}
        </label>

        <input
          id="email"
          type="email"
          formControlName="email"
          autocomplete="email"
          [placeholder]="'pages.register.form.email.placeholder' | translate"
          [class.is-invalid]="isInvalid('email')"
        />

        @if (isInvalid('email')) {
          <p class="form-error">
            {{ 'pages.register.form.email.error' | translate }}
          </p>
        }
      </div>

      <button class="register-submit" type="submit" [disabled]="isFormLocked()">
        @if (isSubmitting()) {
          {{ 'pages.register.form.submitting' | translate }}
