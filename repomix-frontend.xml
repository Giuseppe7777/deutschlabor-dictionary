        </h2>

        <p class="passkey-modal-email">
          {{ pendingRegistrationEmail() }}
        </p>

        <div class="passkey-modal-content">
          <p>
            {{ 'pages.register.passkeyModal.intro' | translate }}
          </p>

          <p>
            {{ 'pages.register.passkeyModal.browserDialog' | translate }}
          </p>

          <p>
            {{ 'pages.register.passkeyModal.privacy' | translate }}
          </p>
        </div>

        @switch (registrationStatus()) {
          @case ('preparing') {
            <p class="form-info">
              {{ 'pages.register.form.messages.preparing' | translate }}
            </p>
          }

          @case ('creatingPasskey') {
            <p class="form-info">
              {{ 'pages.register.form.messages.creatingPasskey' | translate }}
            </p>
          }

          @case ('finishing') {
            <p class="form-info">
